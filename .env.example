# Copie este arquivo para .env e preencha as variáveis

# Django
SECRET_KEY=django-insecure-troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL (usado automaticamente no Docker)
POSTGRES_DB=nba_db
POSTGRES_USER=nba_user
POSTGRES_PASSWORD=nba_password

# Deixe em branco para usar SQLite (desenvolvimento local sem Docker)
# DATABASE_URL=postgresql://nba_user:nba_password@db:5432/nba_db
